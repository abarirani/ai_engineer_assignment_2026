# Visual Recommendations Agentic Workflow - Environment Configuration
# Copy this file to .env and modify as needed
#
# Note: This project uses YAML-based configuration files for managing
# different environments. See app/config/ for configuration files:
#   - base.yaml: Base configuration (common settings)
#   - development.yaml: Development environment overrides
#   - production.yaml: Production environment overrides
#
# This .env file is used only for environment selection and setting secrets.

# Environment selection (default: development)
# Options: development, production
APP_ENV=development

# LLM secret
# OPENAI_API_KEY=your_api_key_here

# Image Editing API secrets
# GEMINI_API_KEY=your_gemini_api_key_here
